# Supabase Auth (Phase 1) — copy this file to `.env.local` and fill in your
# project's values. Both are PUBLIC, client-side values (Vite inlines anything
# prefixed VITE_). Use only the anon / publishable key here.
#
# NEVER put the service_role key in this file or any VITE_ var — it bypasses
# Row Level Security and would be shipped to every visitor.
#
# Find these in the Supabase dashboard → Project Settings → API.
# If either is left blank, the web app runs in localStorage demo mode.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key
