# Euphoria Universe site — environment.
# Copy to .env.local for local dev; set the same vars in the Cloudflare project
# for staging/production. Vite inlines anything prefixed VITE_ at build time.
#
# Supabase: the SAME project as the beta. Only the anon (publishable) key
# belongs here — NEVER the service_role key (it bypasses Row Level Security).
# When these are absent, the interest-signup form degrades to a blog-follow
# fallback instead of erroring (see src/signup/InterestForm.tsx).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: deploy under a subpath host (defaults to "/").
# VITE_BASE=/
