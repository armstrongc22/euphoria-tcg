# Staging area for raw card files; superseded by data/, assets/, _archive/
_incoming/

# Local-machine Claude Code settings
.claude/settings.local.json

# Python
__pycache__/

# Node (for the upcoming packages/ workspace)
node_modules/

# Build output
dist/

# Local env files (Supabase URL + anon key, etc.) — never commit credentials
.env
.env.local
.env.*.local

# Supabase CLI local state (never contains committed schema; can hold tokens)
supabase/.temp/
supabase/.branches/

# Wrangler local dev state
.wrangler/
